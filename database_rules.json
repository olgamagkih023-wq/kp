{
  "rules": {
    "users": {
      "$uid": {
        ".read":  "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },

    "masters": {
      "$uid": {

        "settings": {
          ".read": true,
          ".write": "auth != null && auth.uid === $uid"
        },

        "appointments": {
          ".read": true,
          ".indexOn": ["date"],

          "$apptId": {
            ".write": "(auth != null && auth.uid === $uid) || !data.exists()",

            ".validate": "newData.hasChildren(['client','date','time','status'])",

            "id":       { ".validate": "newData.isString() && newData.val().length <= 64" },
            "client":   { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 100" },
            "phone":    { ".validate": "newData.isString() && newData.val().length <= 30" },
            "telegram": { ".validate": "newData.isString() && newData.val().length <= 64" },
            "vk":       { ".validate": "newData.isString() && newData.val().length <= 64" },
            "service":  { ".validate": "newData.isString() && newData.val().length <= 120" },
            "date":     { ".validate": "newData.isString() && newData.val().matches(/^[0-9]{4}-[0-9]{2}-[0-9]{2}$/)" },
            "time":     { ".validate": "newData.isString() && newData.val().matches(/^[0-9]{1,2}:[0-9]{2}$/)" },
            "price":    { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 1000000" },
            "note":     { ".validate": "newData.isString() && newData.val().length <= 500" },
            "status":   { ".validate": "newData.isString() && newData.val().matches(/^(pending|confirmed|cancelled|done)$/)" },
            "source":   { ".validate": "newData.isString() && newData.val().length <= 20" },
            "created":  { ".validate": "newData.isNumber()" },

            "$other": { ".validate": false }
          }
        }
      }
    },

    "$other": { ".read": false, ".write": false }
  }
}
